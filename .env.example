# Supabase Configuration
# Get these values from the new Supabase project dashboard.
VITE_SUPABASE_URL="https://<new-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<new-publishable-or-anon-key>"

# Edge functions and ingestion scripts
SUPABASE_URL="https://<new-project-ref>.supabase.co"
SUPABASE_ANON_KEY="<new-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<new-service-role-key>"
INTERNAL_INGEST_KEY="<internal-ingest-key>"
CRON_WORKER_KEY="<cron-worker-key>"

# AI providers
OPENAI_API_KEY="<openai-api-key>"
OPENROUTER_API_KEY="<openrouter-api-key>"
AI_PROVIDER="openrouter"

# Unified corpus embeddings/search
# Required by supabase/functions/embed-query and corpus vector search.
EMBEDDING_MODEL="Metric-AI/armenian-text-embeddings-2-large"
EMBEDDING_DB_MODEL="armenian-text-embeddings-2-large"
EMBEDDING_DIM="1024"
EMBEDDING_BATCH="32"
# EMBEDDING_ENDPOINT — query-embedding HTTP service (scripts/embedding_server.py).
# CRITICAL: this is read by the Supabase EDGE functions (vector-search, embed-query),
# which run on Supabase infrastructure — NOT on your VPS. They therefore CANNOT reach
# 127.0.0.1 / localhost / a private LAN IP. In production this MUST be a PUBLIC HTTPS URL
# that resolves to your VPS embedding server (e.g. https://embeddings.ailegalarmenia.com),
# and it MUST be set in Supabase Dashboard -> Edge Functions -> Secrets (not only in .env).
# Use 127.0.0.1:8088 ONLY for local ingestion scripts run on the same machine as the server.
# If unset/unreachable, semantic search SILENTLY degrades to BM25/FTS keyword search.
EMBEDDING_ENDPOINT=""
# Shared secret sent as X-API-Key to the embedding server. Set the SAME value on the VPS
# (EMBEDDING_API_KEY env of embedding_server.py) and in Supabase Edge Function Secrets.
EMBEDDING_API_KEY=""

# CORS
ALLOWED_ORIGINS="https://your-production-domain.example"
ALLOWED_ORIGIN_SUFFIXES=""
